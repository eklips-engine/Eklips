import classes.singleton as engine
from classes.nodes       import *

eklips : Sprite = None

def _process(self : Sprite, delta):
    # Get eklips node
    global eklips
    if not eklips:
        eklips = self.scene.get_node_from_path("/Eklips")
    
    # Rotate the ring
    self.rotation   += (150 + (self.rotation/180)) * delta
    eklips.rotation += 15                          * delta